<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Apps2Samsung.ViewModels"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             mc:Ignorable="d"
             x:Class="Apps2Samsung.Views.LitefinSettingsView"
             x:DataType="viewModels:LitefinSettingsViewModel">

	<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,20,0">
		<StackPanel Spacing="16">

			<!-- Litefin-only notice -->
			<Border Background="#FFF3CD"
					CornerRadius="4"
					Padding="10,8"
					BorderBrush="#FFE69C"
					BorderThickness="1">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<fa:SymbolIcon Symbol="Important" Width="16" Height="16" Foreground="#856404" VerticalAlignment="Center"/>
					<TextBlock Text="{Binding LblLitefinOnlyNotice}"
							   Foreground="#856404"
							   FontSize="12"
							   FontWeight="SemiBold"
							   TextWrapping="Wrap"
							   VerticalAlignment="Center"/>
				</StackPanel>
			</Border>

			<!-- Icon style -->
			<StackPanel Spacing="4">
				<Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
					<TextBlock Grid.Column="0"
							   Text="{Binding LblOblongIcon}"
							   Classes="label"
							   VerticalAlignment="Center"/>
					<ToggleSwitch Grid.Column="1"
								  IsChecked="{Binding UseOblongIcon}"
								  VerticalAlignment="Center"/>
				</Grid>
				<TextBlock Text="{Binding LblOblongIconHint}"
						   FontSize="11"
						   FontStyle="Italic"
						   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
						   TextWrapping="Wrap"/>
			</StackPanel>

		</StackPanel>
	</ScrollViewer>
</UserControl>
